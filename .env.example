# ============================================================================
# ExecFlow — Variáveis de Ambiente (MODELO)
# ============================================================================
# Copie os valores relevantes para os arquivos .env.local de cada serviço:
#   - packages/db/.env.local      → DATABASE_URL (migrations/seeds)
#   - apps/api/.env.local         → API (auth, storage, claude, smtp)
#   - packages/workers/.env.local → WORKERS (jusbrasil, smtp, claude)
#   - apps/web/.env.local         → FRONTEND (NEXT_PUBLIC_API_URL)
#
# Dica: DATABASE_URL é igual nos três (db/api/workers) — pode repetir o mesmo
# arquivo. NUNCA commite os .env.local (já estão no .gitignore).
# ============================================================================

# ----------------------------------------------------------------------------
# BANCO DE DADOS  (db + api + workers)  ★ OBRIGATÓRIO
# ----------------------------------------------------------------------------
# Supabase/Postgres. Use a connection string "session pooler" (porta 5432).
DATABASE_URL=postgresql://postgres:SENHA@HOST:5432/postgres

# ----------------------------------------------------------------------------
# AUTENTICAÇÃO — Better Auth  (api)  ★ OBRIGATÓRIO
# ----------------------------------------------------------------------------
# Gere um segredo forte: openssl rand -base64 32
BETTER_AUTH_SECRET=troque-por-um-segredo-aleatorio-forte
BETTER_AUTH_URL=http://localhost:3001
# Origens confiáveis para CORS/cookies (separadas por vírgula). Em prod, o domínio do web.
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000
# Segredo para assinar tokens de upload (pode reaproveitar o de cima ou outro).
UPLOAD_TOKEN_SECRET=outro-segredo-aleatorio

# ----------------------------------------------------------------------------
# FRONTEND  (web)  ★ OBRIGATÓRIO
# ----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001

# ----------------------------------------------------------------------------
# CLAUDE (Anthropic)  (api + workers)  ★ OBRIGATÓRIO p/ redigir peças
# ----------------------------------------------------------------------------
# Console: https://console.anthropic.com/  → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ----------------------------------------------------------------------------
# JUSBRASIL — MOTOR ÚNICO de tribunais  (workers + api)  ★ OBRIGATÓRIO
# ----------------------------------------------------------------------------
# Token UUID obtido com o suporte Jusbrasil: suportesolucoes@jusbrasil.com.br
# Formato: 0bb5e3a5-cd56-46c1-8552-061839f07aaa
JUSBRASIL_API_KEY=
# Token de segurança do callback (defina o mesmo valor ao configurar o webhook no Jusbrasil).
JUSBRASIL_WEBHOOK_TOKEN=
# URL pública do webhook que o monitoramento vai chamar (deve apontar para a API):
#   https://SEU-DOMINIO-API/api/v1/webhooks/jusbrasil
JUSBRASIL_WEBHOOK_URL=https://SEU-DOMINIO-API/api/v1/webhooks/jusbrasil
# Base pública da API (usada para montar a URL do webhook se a de cima ficar vazia).
PUBLIC_API_URL=http://localhost:3001
# URL base da API Jusbrasil (padrão: https://api.jusbrasil.com.br).
# Se o suporte indicar a URL Digesto, use: https://op.digesto.com.br/api
JUSBRASIL_API_URL=https://api.jusbrasil.com.br

# ----------------------------------------------------------------------------
# ASTREA — monitoramento de tribunais via e-mail (IMAP)  (workers)  ★ OBRIGATÓRIO
# ----------------------------------------------------------------------------
# Gmail dedicado configurado no Astrea para receber "todos os processos
# públicos do escritório" por e-mail. NÃO use o Gmail pessoal do advogado.
ASTREA_IMAP_HOST=imap.gmail.com
ASTREA_IMAP_PORT=993
ASTREA_IMAP_USER=
# Senha de app do Google (NÃO a senha normal da conta).
# Gere em myaccount.google.com/apppasswords (requer verificação em 2 etapas).
ASTREA_IMAP_PASS=
# Pasta de origem onde o Astrea entrega (normalmente INBOX).
ASTREA_IMAP_SOURCE_FOLDER=INBOX
# Prefixo das subpastas de trilha auditável, criadas automaticamente.
ASTREA_IMAP_FOLDER_PREFIX=ExecFlow
# Liga/desliga o poller sem remover credenciais (para manutenção/teste).
ASTREA_EMAIL_POLL_ENABLED=true
# Para onde mandar alertas de saúde do pipeline. DEVE SER DIFERENTE de
# ASTREA_IMAP_USER (evita loop de notificação dentro da própria caixa monitorada).
ASTREA_HEALTH_ALERT_EMAIL=miguelgalvao.adv@gmail.com
# Modelo Claude usado na extração estruturada de e-mail (fallback do regex).
# Reaproveita ANTHROPIC_API_KEY já definida acima.
ASTREA_EMAIL_EXTRACTION_MODEL=claude-haiku-4-5

# ----------------------------------------------------------------------------
# AASP — API de Intimações (push webhook)  (api)  ★ OBRIGATÓRIO se assina AASP
# ----------------------------------------------------------------------------
# Registre sua integração em: intimacaoapi-cadastro.aasp.org.br
# URL de callback a fornecer: https://SEU-DOMINIO-API/api/v1/webhooks/aasp
# Após o registro, guarde o token recebido aqui.
AASP_WEBHOOK_TOKEN=
# Kill-switch para pausar sem remover a credencial.
AASP_WEBHOOK_ENABLED=true

# ----------------------------------------------------------------------------
# DJEN / Comunica — intimações oficiais por OAB  (workers)
# GRÁTIS, SEM CNPJ, SEM CHAVE. Canal oficial de intimações (Diário de Justiça
# Eletrônico Nacional). Consulta por número da OAB — cadastre perfis em
# /inventory ou liste aqui. É a alternativa à AASP para quem não tem CNPJ.
# ----------------------------------------------------------------------------
DJEN_ENABLED=true
# DJEN_OABS=123456/SP,654321/MG

# ----------------------------------------------------------------------------
# Reanálise worker → API (DataJud/DJEN disparam a cadeia de oportunidades/prazo)
# Gerado automaticamente; o MESMO valor deve estar em apps/api e workers.
# ----------------------------------------------------------------------------
EXECFLOW_API_URL=http://localhost:3001
INTERNAL_API_TOKEN=troque-por-um-segredo-aleatorio-forte

# ----------------------------------------------------------------------------
# STORAGE — autos e documentos  (api + workers)  ★ OBRIGATÓRIO
# ----------------------------------------------------------------------------
# Dev: local (grava em .storage/). Prod: s3 (Cloudflare R2 recomendado).
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=.storage
STORAGE_API_BASE_URL=http://localhost:3001
# --- Apenas se STORAGE_PROVIDER=s3 (R2/S3) ---
STORAGE_S3_BUCKET=
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=
STORAGE_S3_REGION=auto
# R2: https://<accountid>.r2.cloudflarestorage.com
STORAGE_S3_ENDPOINT=
STORAGE_S3_FORCE_PATH_STYLE=true

# ----------------------------------------------------------------------------
# E-MAIL (notificações de prazo/oportunidade/movimentação)  (api + workers)
# ----------------------------------------------------------------------------
# Gmail: use uma "Senha de app" (não a senha da conta).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
# Para onde vão os alertas do escritório.
OFFICE_EMAIL=miguelgalvao.adv@gmail.com

# ----------------------------------------------------------------------------
# RUNTIME
# ----------------------------------------------------------------------------
NODE_ENV=development
PORT=3001
