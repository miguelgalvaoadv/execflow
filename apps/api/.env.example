# =============================================================================
# EXECFLOW API — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local or any file with real credentials.
# =============================================================================

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
# Local development (Docker): infrastructure/docker-compose.dev.yml
#   DATABASE_URL=postgresql://execflow:execflow@localhost:5432/execflow
#
# Hosted (Neon): dashboard → Connection Details; use a dev branch URL.
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://execflow:execflow@localhost:5432/execflow

# ---------------------------------------------------------------------------
# Better Auth
# ---------------------------------------------------------------------------
# A cryptographically random secret. Generate with: openssl rand -base64 32
# Must be at least 32 characters. Never reuse across environments.
BETTER_AUTH_SECRET=replace-with-32-plus-char-random-secret

# The URL of THIS API server (used by Better Auth for callback URLs).
# Development: http://localhost:3001
# Production: https://api.execflow.com (or your Fly.io domain)
BETTER_AUTH_URL=http://localhost:3001

# Comma-separated list of frontend origins allowed to call this API.
# Development: http://localhost:3000
# Production: https://app.execflow.com
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000

# ---------------------------------------------------------------------------
# API Server
# ---------------------------------------------------------------------------
# Port this server listens on. Defaults to 3001 in code.
PORT=3001

# Environment identifier. Controls logging verbosity and error detail.
# Values: development | production | test
NODE_ENV=development

# ---------------------------------------------------------------------------
# Blob storage (upload layer)
# ---------------------------------------------------------------------------
# Provider: local (dev/test filesystem) | s3 (R2, AWS S3, MinIO)
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=.storage
# Base URL for local presigned PUT target (defaults to BETTER_AUTH_URL)
STORAGE_API_BASE_URL=http://localhost:3001
# HMAC secret for upload tokens (defaults to BETTER_AUTH_SECRET if unset)
# UPLOAD_TOKEN_SECRET=
# Max upload size in bytes (default 52428800 = 50 MiB)
# STORAGE_MAX_UPLOAD_BYTES=52428800
# Presigned URL TTL seconds (default 900)
# STORAGE_UPLOAD_EXPIRES_SECONDS=900

# S3-compatible (STORAGE_PROVIDER=s3) — Cloudflare R2 example:
# STORAGE_S3_BUCKET=execflow-documents
# STORAGE_S3_REGION=auto
# STORAGE_S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# STORAGE_S3_ACCESS_KEY_ID=
# STORAGE_S3_SECRET_ACCESS_KEY=
# STORAGE_S3_FORCE_PATH_STYLE=false
