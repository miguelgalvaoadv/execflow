# =============================================================================
# EXECFLOW @execflow/db — Drizzle CLI & seed
# Copy to .env.local (do not commit .env.local).
# =============================================================================

# Same PostgreSQL URL as apps/api and packages/workers.
#
# Local Docker (see infrastructure/docker-compose.dev.yml):
#   DATABASE_URL=postgresql://execflow:execflow@localhost:5432/execflow
#
# Neon or other hosted:
#   DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
#
DATABASE_URL=postgresql://execflow:execflow@localhost:5432/execflow

# Disposable DB for migration integration tests (pnpm test:migrations).
# Never point at production — the test run DROP SCHEMA public CASCADE.
# MIGRATION_TEST_DATABASE_URL=postgresql://execflow:execflow@localhost:5432/execflow_test
